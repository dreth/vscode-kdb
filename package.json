{
  "name": "vscode-kdb",
  "displayName": "KX for VS Code",
  "description": "Standalone direct q IPC, persistent Jupyter notebook results, and high-performance KX results for VS Code.",
  "version": "0.2.2",
  "publisher": "DanielAlonso",
  "license": "MIT",
  "icon": "icons/kx-marketplace.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dreth/vscode-kdb.git"
  },
  "bugs": {
    "url": "https://github.com/dreth/vscode-kdb/issues"
  },
  "homepage": "https://github.com/dreth/vscode-kdb#readme",
  "categories": [
    "Programming Languages",
    "Data Science",
    "Visualization",
    "Notebooks"
  ],
  "keywords": [
    "kx",
    "kdb",
    "kdb+",
    "q",
    "q ipc",
    "time series",
    "jupyter",
    "notebooks"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:q",
    "onRenderer:vscode-kdb.kx-notebook-renderer",
    "onView:vscode-kdb.connections",
    "onView:vscode-kdb.serverExplorer",
    "onView:vscode-kdb.queryHistory",
    "onCommand:vscode-kdb.addConnection",
    "onCommand:vscode-kdb.editConnection",
    "onCommand:vscode-kdb.removeConnection",
    "onCommand:vscode-kdb.setActiveConnection",
    "onCommand:vscode-kdb.connect",
    "onCommand:vscode-kdb.disconnect",
    "onCommand:vscode-kdb.testConnection",
    "onCommand:vscode-kdb.importSqlToolsConnections",
    "onCommand:vscode-kdb.refreshConnections",
    "onCommand:vscode-kdb.refreshServerExplorer",
    "onCommand:vscode-kdb.previewServerObject",
    "onCommand:vscode-kdb.rerunQueryHistoryEntry",
    "onCommand:vscode-kdb.copyQueryHistoryEntry",
    "onCommand:vscode-kdb.insertQueryHistoryEntry",
    "onCommand:vscode-kdb.deleteQueryHistoryEntry",
    "onCommand:vscode-kdb.clearQueryHistory",
    "onCommand:vscode-kdb.runSelectionOrCurrentLine",
    "onCommand:vscode-kdb.runScript",
    "onCommand:vscode-kdb.runSelectionInNewResult",
    "onCommand:vscode-kdb.copyResultSelection",
    "onCommand:vscode-kdb.openLocalDataServer",
    "onCommand:vscode-kdb.stopLocalDataServer",
    "onCommand:vscode-kdb.copyLocalDataServerUrl",
    "onCommand:vscode-kdb.setNotebookCellLanguageQ",
    "onCommand:vscode-kdb.restoreNotebookCellLanguage",
    "onCommand:vscode-kdb.tagNotebookCellAsQ",
    "onCommand:vscode-kdb.prepareNotebookCellForPythonKernel",
    "onCommand:vscode-kdb.openNotebookPreviewInResults"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run compile:renderer",
    "compile:extension": "tsc -p ./",
    "compile:renderer": "tsc -p renderer/tsconfig.json --noEmit && esbuild renderer/index.ts --bundle --format=esm --platform=browser --target=es2022 --loader:.css=text --outfile=renderer/kx-notebook-renderer.js --minify --legal-comments=none",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node test/run.js",
    "test:unit": "npm run compile && node test/run.js",
    "test:notebook-python": "uv run --python 3.9 --no-project --with-editable ./python/kx_notebook python -m unittest discover -s python/kx_notebook/tests -v",
    "test:notebook-cross": "npm run compile && node scripts/check-notebook-contract.js",
    "test:live-q": "npm run compile && node test/live/run.js",
    "test:parity": "node scripts/run-cross-parity.js",
    "test:parity:self": "node test/parity/self-test.js",
    "test:parity:strict": "node scripts/run-cross-parity.js --fail-on-known-gap",
    "package": "npm run compile && vsce package --out vscode-kdb-0.2.2.vsix",
    "package:vsix": "npm run compile && vsce package --out vscode-kdb-0.2.2.vsix"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.96.0",
    "@types/vscode-notebook-renderer": "^1.72.4",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "q",
        "aliases": [
          "q",
          "KX q",
          "kdb+ q"
        ],
        "extensions": [
          ".q"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "q",
        "scopeName": "source.q",
        "path": "./syntaxes/q.tmLanguage.json"
      }
    ],
    "notebookRenderer": [
      {
        "id": "vscode-kdb.kx-notebook-renderer",
        "displayName": "KX Notebook Result",
        "entrypoint": "./renderer/kx-notebook-renderer.js",
        "mimeTypes": [
          "application/vnd.kx.result+json"
        ],
        "requiresMessaging": "optional"
      }
    ],
    "commands": [
      {
        "command": "vscode-kdb.addConnection",
        "title": "KX: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "vscode-kdb.editConnection",
        "title": "KX: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "vscode-kdb.removeConnection",
        "title": "KX: Remove Connection",
        "icon": "$(trash)"
      },
      {
        "command": "vscode-kdb.setActiveConnection",
        "title": "KX: Set Active Connection",
        "icon": "$(star-full)"
      },
      {
        "command": "vscode-kdb.connect",
        "title": "KX: Connect",
        "icon": "$(debug-start)"
      },
      {
        "command": "vscode-kdb.disconnect",
        "title": "KX: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "vscode-kdb.testConnection",
        "title": "KX: Test Connection",
        "icon": "$(beaker)"
      },
      {
        "command": "vscode-kdb.importSqlToolsConnections",
        "title": "KX: Import SQLTools KDB Connections",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vscode-kdb.refreshConnections",
        "title": "KX: Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "vscode-kdb.refreshServerExplorer",
        "title": "KX: Refresh Server Explorer",
        "icon": "$(refresh)",
        "enablement": "config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available"
      },
      {
        "command": "vscode-kdb.previewServerObject",
        "title": "KX: Preview Server Object",
        "icon": "$(open-preview)",
        "enablement": "config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available"
      },
      {
        "command": "vscode-kdb.rerunQueryHistoryEntry",
        "title": "KX Query History: Rerun Query",
        "icon": "$(play)",
        "enablement": "config.vscode-kdb.features.queryHistory"
      },
      {
        "command": "vscode-kdb.copyQueryHistoryEntry",
        "title": "KX Query History: Copy Query",
        "icon": "$(copy)",
        "enablement": "config.vscode-kdb.features.queryHistory"
      },
      {
        "command": "vscode-kdb.insertQueryHistoryEntry",
        "title": "KX Query History: Insert into Active Editor",
        "icon": "$(insert)",
        "enablement": "config.vscode-kdb.features.queryHistory"
      },
      {
        "command": "vscode-kdb.deleteQueryHistoryEntry",
        "title": "KX Query History: Delete Entry",
        "icon": "$(trash)",
        "enablement": "config.vscode-kdb.features.queryHistory"
      },
      {
        "command": "vscode-kdb.clearQueryHistory",
        "title": "KX: Clear Query History",
        "icon": "$(clear-all)",
        "enablement": "config.vscode-kdb.features.queryHistory"
      },
      {
        "command": "vscode-kdb.runSelectionOrCurrentLine",
        "title": "KX: Run Selection / Current Line",
        "icon": "$(play)"
      },
      {
        "command": "vscode-kdb.runScript",
        "title": "KX: Run q Script",
        "icon": "$(run-all)"
      },
      {
        "command": "vscode-kdb.runSelectionInNewResult",
        "title": "KX: Run Selection in New Result",
        "icon": "$(open-preview)"
      },
      {
        "command": "vscode-kdb.copyResultSelection",
        "title": "KX Results: Copy Selection",
        "icon": "$(copy)"
      },
      {
        "command": "vscode-kdb.openLocalDataServer",
        "title": "KX Results: Start Local Data Server",
        "icon": "$(server-process)"
      },
      {
        "command": "vscode-kdb.stopLocalDataServer",
        "title": "KX Results: Stop Local Data Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "vscode-kdb.copyLocalDataServerUrl",
        "title": "KX Results: Copy Local Data Server URL",
        "icon": "$(link)"
      },
      {
        "command": "vscode-kdb.setNotebookCellLanguageQ",
        "title": "KX: Set Notebook Cell Language to q",
        "icon": "$(symbol-keyword)",
        "enablement": "notebookType == 'jupyter-notebook'"
      },
      {
        "command": "vscode-kdb.restoreNotebookCellLanguage",
        "title": "KX: Restore Notebook Cell Language",
        "icon": "$(discard)",
        "enablement": "notebookType == 'jupyter-notebook' && vscode-kdb.notebookDefaultLanguageAvailable"
      },
      {
        "command": "vscode-kdb.tagNotebookCellAsQ",
        "title": "KX: Tag Notebook Cell as q",
        "icon": "$(tag)",
        "enablement": "notebookType == 'jupyter-notebook'"
      },
      {
        "command": "vscode-kdb.prepareNotebookCellForPythonKernel",
        "title": "Prepare this q cell for the active Python kernel",
        "icon": "$(lightbulb)",
        "enablement": "notebookType == 'jupyter-notebook' && vscode-kdb.notebookQCellNeedsKernelPreparation"
      },
      {
        "command": "vscode-kdb.openNotebookPreviewInResults",
        "title": "KX: Open Saved Notebook Preview in Results Panel",
        "icon": "$(open-preview)",
        "enablement": "vscode-kdb.notebookResultAvailable"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-kdb.runSelectionOrCurrentLine",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && !notebookEditorFocused && (editorLangId == q || resourceExtname == .q)"
      },
      {
        "command": "vscode-kdb.runScript",
        "key": "ctrl+alt+enter",
        "mac": "cmd+alt+enter",
        "when": "editorTextFocus && !notebookEditorFocused && (editorLangId == q || resourceExtname == .q)"
      },
      {
        "command": "vscode-kdb.runSelectionInNewResult",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && !notebookEditorFocused && (editorLangId == q || resourceExtname == .q)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-kdb",
          "title": "KX",
          "icon": "icons/kx-activity.png"
        }
      ]
    },
    "views": {
      "vscode-kdb": [
        {
          "id": "vscode-kdb.connections",
          "name": "KX Connections",
          "contextualTitle": "KX Connections"
        },
        {
          "id": "vscode-kdb.serverExplorer",
          "name": "KX Server Explorer",
          "contextualTitle": "KX Server Explorer",
          "when": "config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available"
        },
        {
          "id": "vscode-kdb.queryHistory",
          "name": "KX Query History",
          "contextualTitle": "KX Query History",
          "when": "config.vscode-kdb.features.queryHistory"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscode-kdb.addConnection",
          "when": "view == vscode-kdb.connections",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.importSqlToolsConnections",
          "when": "view == vscode-kdb.connections",
          "group": "navigation@2"
        },
        {
          "command": "vscode-kdb.refreshConnections",
          "when": "view == vscode-kdb.connections",
          "group": "navigation@3"
        },
        {
          "command": "vscode-kdb.refreshServerExplorer",
          "when": "view == vscode-kdb.serverExplorer && config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.clearQueryHistory",
          "when": "view == vscode-kdb.queryHistory && config.vscode-kdb.features.queryHistory",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-kdb.importSqlToolsConnections",
          "when": "view == vscode-kdb.connections && viewItem == vscode-kdb.connections.empty",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.connect",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\.disconnected\\./",
          "group": "inline@1"
        },
        {
          "command": "vscode-kdb.disconnect",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\.connected\\./",
          "group": "inline@1"
        },
        {
          "command": "vscode-kdb.setActiveConnection",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\.(connected|disconnected)\\.inactive$/",
          "group": "inline@2"
        },
        {
          "command": "vscode-kdb.testConnection",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\./",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.editConnection",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\./",
          "group": "navigation@2"
        },
        {
          "command": "vscode-kdb.removeConnection",
          "when": "view == vscode-kdb.connections && viewItem =~ /^vscode-kdb\\.connection\\./",
          "group": "navigation@3"
        },
        {
          "command": "vscode-kdb.previewServerObject",
          "when": "view == vscode-kdb.serverExplorer && viewItem =~ /^vscode-kdb\\.serverExplorer\\.object\\.(table|variable)$/ && config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available",
          "group": "inline@1"
        },
        {
          "command": "vscode-kdb.rerunQueryHistoryEntry",
          "when": "view == vscode-kdb.queryHistory && viewItem =~ /^vscode-kdb\\.queryHistory\\.entry\\./ && config.vscode-kdb.features.queryHistory",
          "group": "inline@1"
        },
        {
          "command": "vscode-kdb.copyQueryHistoryEntry",
          "when": "view == vscode-kdb.queryHistory && viewItem =~ /^vscode-kdb\\.queryHistory\\.entry\\./ && config.vscode-kdb.features.queryHistory",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.insertQueryHistoryEntry",
          "when": "view == vscode-kdb.queryHistory && viewItem =~ /^vscode-kdb\\.queryHistory\\.entry\\./ && config.vscode-kdb.features.queryHistory",
          "group": "navigation@2"
        },
        {
          "command": "vscode-kdb.deleteQueryHistoryEntry",
          "when": "view == vscode-kdb.queryHistory && viewItem =~ /^vscode-kdb\\.queryHistory\\.entry\\./ && config.vscode-kdb.features.queryHistory",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "vscode-kdb.runSelectionOrCurrentLine",
          "when": "notebookType != 'jupyter-notebook'"
        },
        {
          "command": "vscode-kdb.runScript",
          "when": "notebookType != 'jupyter-notebook'"
        },
        {
          "command": "vscode-kdb.runSelectionInNewResult",
          "when": "notebookType != 'jupyter-notebook'"
        },
        {
          "command": "vscode-kdb.refreshServerExplorer",
          "when": "config.vscode-kdb.features.serverExplorer && vscode-kdb.serverExplorer.available"
        },
        {
          "command": "vscode-kdb.previewServerObject",
          "when": "false"
        },
        {
          "command": "vscode-kdb.rerunQueryHistoryEntry",
          "when": "false"
        },
        {
          "command": "vscode-kdb.copyQueryHistoryEntry",
          "when": "false"
        },
        {
          "command": "vscode-kdb.insertQueryHistoryEntry",
          "when": "false"
        },
        {
          "command": "vscode-kdb.deleteQueryHistoryEntry",
          "when": "false"
        },
        {
          "command": "vscode-kdb.clearQueryHistory",
          "when": "config.vscode-kdb.features.queryHistory"
        },
        {
          "command": "vscode-kdb.setNotebookCellLanguageQ",
          "when": "notebookType == 'jupyter-notebook'"
        },
        {
          "command": "vscode-kdb.restoreNotebookCellLanguage",
          "when": "notebookType == 'jupyter-notebook' && vscode-kdb.notebookDefaultLanguageAvailable"
        },
        {
          "command": "vscode-kdb.tagNotebookCellAsQ",
          "when": "notebookType == 'jupyter-notebook'"
        },
        {
          "command": "vscode-kdb.prepareNotebookCellForPythonKernel",
          "when": "notebookType == 'jupyter-notebook' && vscode-kdb.notebookQCellNeedsKernelPreparation"
        },
        {
          "command": "vscode-kdb.openNotebookPreviewInResults",
          "when": "vscode-kdb.notebookResultAvailable"
        }
      ],
      "editor/title": [
        {
          "command": "vscode-kdb.runSelectionOrCurrentLine",
          "when": "!notebookEditorFocused && (editorLangId == q || resourceExtname == .q)",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vscode-kdb.runSelectionOrCurrentLine",
          "when": "!notebookEditorFocused && (editorLangId == q || resourceExtname == .q)",
          "group": "navigation@1"
        },
        {
          "command": "vscode-kdb.runScript",
          "when": "!notebookEditorFocused && (editorLangId == q || resourceExtname == .q)",
          "group": "navigation@2"
        },
        {
          "command": "vscode-kdb.runSelectionInNewResult",
          "when": "!notebookEditorFocused && (editorLangId == q || resourceExtname == .q)",
          "group": "navigation@3"
        }
      ],
      "notebook/cell/title": [
        {
          "command": "vscode-kdb.setNotebookCellLanguageQ",
          "when": "notebookEditorFocused && notebookType == 'jupyter-notebook' && notebookCellType == 'code'",
          "group": "inline@19"
        },
        {
          "command": "vscode-kdb.restoreNotebookCellLanguage",
          "when": "notebookEditorFocused && notebookType == 'jupyter-notebook' && notebookCellType == 'code' && vscode-kdb.notebookDefaultLanguageAvailable",
          "group": "1_modification@1"
        },
        {
          "command": "vscode-kdb.tagNotebookCellAsQ",
          "when": "notebookEditorFocused && notebookType == 'jupyter-notebook' && notebookCellType == 'code'",
          "group": "1_modification@2"
        },
        {
          "command": "vscode-kdb.prepareNotebookCellForPythonKernel",
          "when": "notebookEditorFocused && notebookType == 'jupyter-notebook' && notebookCellType == 'code' && vscode-kdb.notebookQCellNeedsKernelPreparation",
          "group": "1_modification@3"
        },
        {
          "command": "vscode-kdb.openNotebookPreviewInResults",
          "when": "notebookEditorFocused && notebookType == 'jupyter-notebook' && vscode-kdb.notebookResultAvailable",
          "group": "inline@21"
        }
      ],
      "webview/context": [
        {
          "command": "vscode-kdb.copyResultSelection",
          "when": "webviewId == vscodeKdbResults && webviewSection == kxResultsTable",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "KX for VS Code",
      "properties": {
        "vscode-kdb.notebook.presentation": {
          "type": "string",
          "scope": "window",
          "default": "inline",
          "enum": [
            "inline",
            "panel",
            "both"
          ],
          "description": "Presentation for KX MIME results in ordinary Jupyter/IPython notebooks. Inline is the default; panel opens only the saved bounded preview in the KX Results panel; both keeps inline output and also opens that saved preview in the panel. This does not intercept Jupyter execution or recover omitted rows."
        },
        "vscode-kdb.notebook.maxOutputRows": {
          "type": "integer",
          "scope": "window",
          "default": 1000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum preview rows written by newly tagged %%q cells. The tag command persists this limit in the cell magic; kx_notebook also validates its own explicit limits. Full large results remain only in the originating live q session or a live KX panel."
        },
        "vscode-kdb.notebook.maxOutputBytes": {
          "type": "integer",
          "scope": "window",
          "default": 1000000,
          "minimum": 16384,
          "maximum": 10000000,
          "description": "Maximum combined portable MIME body bytes requested by newly tagged %%q cells. The helper applies this budget across rich JSON and static HTML/plain fallbacks from the same preview; no credentials or IPC handles are stored."
        },
        "vscode-kdb.features.serverExplorer": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable the first-party KX Server Explorer for the active direct q IPC profile. Disabled by default; disconnected state stays visible, and metadata is loaded only while connected when Refresh or table expansion is explicitly invoked."
        },
        "vscode-kdb.features.queryHistory": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable privacy-aware Query History. Disabled by default; issued editor query text is stored only in local VS Code workspace extension storage and is not sent as telemetry or placed in Settings Sync."
        },
        "vscode-kdb.serverExplorer.previewCellLimit": {
          "type": "integer",
          "scope": "window",
          "default": 10000,
          "minimum": 1,
          "maximum": 1000000,
          "description": "Server-side table/variable preview cap: approximate cells for tables and outer items for lists/dictionaries. Preview always requires explicit confirmation; nested values can still be large, and functions/projections are metadata-only."
        },
        "vscode-kdb.queryHistory.maxEntries": {
          "type": "integer",
          "scope": "window",
          "default": 100,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum query-text entries retained in local VS Code workspace extension storage when Query History is enabled. Result payloads are never stored."
        },
        "vscode-kdb.connections": {
          "type": "array",
          "scope": "application",
          "default": [],
          "description": "Global direct q IPC connections. Authentication secrets are stored separately in VS Code SecretStorage.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "host",
              "port",
              "database",
              "username"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
                "description": "Extension-generated stable connection ID."
              },
              "name": {
